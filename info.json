    {
      "name": "dprint-plugin-exec",
      "description": "Formats code using formatting CLIs installed on the host machine (rustfmt, clang-format, shfmt, etc.).",
      "selected": false,
      "configKey": "exec",
      "fileExtensions": [],
      "configExcludes": [],
      "defaultConfig": {
        "cwd": "${configDir}"
      },
      "configItems": [
        {
          "match": {
            "fileExtensions": [
              "rs"
            ]
          },
          "config": {
            "commands": [
              {
                "command": "rustfmt",
                "exts": [
                  "rs"
                ]
              }
            ]
          }
        },
        {
          "match": {
            "fileExtensions": [
              "c",
              "cc",
              "cpp",
              "cxx",
              "h",
              "hpp",
              "hxx",
              "m",
              "mm"
            ]
          },
          "config": {
            "commands": [
              {
                "command": "clang-format",
                "exts": [
                  "c",
                  "cc",
                  "cpp",
                  "cxx",
                  "h",
                  "hpp",
                  "hxx",
                  "m",
                  "mm"
                ]
              }
            ]
          }
        },
        {
          "match": {
            "fileExtensions": [
              "sh",
              "bash"
            ]
          },
          "config": {
            "commands": [
              {
                "command": "shfmt",
                "exts": [
                  "sh",
                  "bash"
                ]
              }
            ]
          }
        },
        {
          "match": {
            "fileExtensions": [
              "zig"
            ]
          },
          "config": {
            "commands": [
              {
                "command": "zig fmt --stdin",
                "exts": [
                  "zig"
                ]
              }
            ]
          }
        }
      ]
    }
